---
source: crates/agentgateway/src/types/local_tests.rs
description: "Config normalization test for llm_mcp_same_port: YAML -> LocalConfig -> NormalizedLocalConfig -> YAML"
---
binds:
  - key: bind/3000
    address: "[::]:3000"
    protocol: http
    tunnelProtocol: direct
    listeners:
      llm:
        gatewayName: name
        gatewayNamespace: ns
        hostname: "*"
        key: llm
        listenerName: llm
        protocol: HTTP
listener_routes:
  - - llm
    - - key: "llm:request"
        llmRouter:
          models:
            - name: gpt-4
              visibility: public
              headerMatches: []
              backendKey: "llm:model:gpt-4:0"
              routePolicies:
                - ai:
                    routes:
                      "*": passthrough
                      /v1/chat/completions: completions
                      /v1/embeddings: embeddings
                      /v1/images/edits: detect
                      /v1/images/generations: detect
                      /v1/images/variations: detect
                      /v1/messages: messages
                      /v1/rerank: rerank
                      /v1/responses: responses
                      /v1/responses/compact: detect
                      /v2/rerank: rerank
                      ":rawPredict": messages
                      ":streamRawPredict": messages
              backendPolicies: []
          virtualModels: []
          created: 0
        matches:
          - path:
              pathPrefix: /
        name: "llm:request"
        namespace: internal
      - backends:
          - backend: /mcp
            weight: 1
        key: "mcp:default"
        matches:
          - path:
              pathPrefix: /mcp
          - path:
              pathPrefix: /.well-known
        name: default
        namespace: internal
listener_tcp_routes:
  - - llm
    - []
policies: []
backends:
  - backend:
      ai:
        name: "llm:model:gpt-4:0"
        namespace: ""
        target:
          providers:
            - active:
                gpt-4:
                  endpoint:
                    name: gpt-4
                    provider:
                      openAI: {}
                    hostOverride: ~
                    pathOverride: ~
                    pathPrefix: ~
                    tokenize: false
                  info:
                    health: 1
                    requestLatency: 0
                    pendingRequests: 0
                    totalRequests: 0
                    consecutiveFailures: 0
                    timesEjected: 0
                    evictedUntil: ~
                  capacity: 1
              rejected: {}
    inlinePolicies:
      - ai: {}
  - backend:
      mcp:
        name: mcp
        namespace: ""
        target:
          targets:
            - name: time
              stdio:
                cmd: uvx
                args:
                  - mcp-server-time
          stateful: true
          alwaysUsePrefix: false
          failureMode: failClosed
          sessionIdleTtl: 30m0s
route_groups: []
workloads: []
services: []
