{
  "name": "agentgateway-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_AGENTGATEWAY_API=http://localhost:15000 vite --host 0.0.0.0 --port 19000",
    "build": "npm run generate-schema && tsc -b && vite build",
    "lint": "npm run typecheck && npm run format:check",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{ts,js,json}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{ts,js,json}\" \"scripts/**/*.mjs\"",
    "typecheck": "npm run generate-schema && tsc -b",
    "preview": "vite preview --host 0.0.0.0 --port 19001",
    "generate-schema": "node scripts/generate-schema.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@monaco-editor/react": "^4.7.0",
    "@number-flow/react": "^0.6.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.139.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.53.0",
    "monaco-yaml": "^5.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "ajv": "^8.20.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.4",
    "typescript": "5.9.3",
    "vite": "^8.0.16"
  }
}
