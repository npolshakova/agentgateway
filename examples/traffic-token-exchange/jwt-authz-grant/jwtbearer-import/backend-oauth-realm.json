{
  "realm": "backend-oauth",
  "enabled": true,
  "sslRequired": "NONE",
  "displayName": "Agentgateway Token Exchange",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "clients": [
    {
      "clientId": "initial-client",
      "name": "initial client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "initial-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "defaultClientScopes": [
        "profile",
        "email",
        "requester-audience"
      ]
    },
    {
      "clientId": "requester-client",
      "name": "requester client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "requester-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "implicitFlowEnabled": false,
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "oauth2.jwt.authorization.grant.enabled": "true",
        "oauth2.jwt.authorization.grant.idp": "idp-jwt"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "target-audience"
      ]
    },
    {
      "clientId": "target-client",
      "name": "target client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "target-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false
    }
  ],
  "clientScopes": [
    {
      "name": "requester-audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "requester-client",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "included.custom.audience": "requester-client",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "target-audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "target-client",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "included.custom.audience": "target-client",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "profile",
    "email"
  ],
  "defaultOptionalClientScopes": [
    "offline_access"
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "test@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ]
    },
    {
      "username": "idpuser",
      "enabled": true,
      "email": "idpuser@example.com",
      "emailVerified": true,
      "firstName": "Idp",
      "lastName": "User",
      "federatedIdentities": [
        {
          "identityProvider": "idp-jwt",
          "userId": "11111111-2222-3333-4444-555555555555",
          "userName": "idpuser"
        }
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "idp-jwt",
      "providerId": "jwt-authorization-grant",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "config": {
        "validateSignature": "true",
        "jwtAuthorizationGrantEnabled": "true",
        "jwksUrl": "http://localhost:7080/realms/idp/protocol/openid-connect/certs",
        "issuer": "http://localhost:7080/realms/idp",
        "useJwksUrl": "true"
      }
    }
  ]
}
